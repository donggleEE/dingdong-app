}

enum _CardTone { green, pink }

class _MetricCard extends StatelessWidget {
  const _MetricCard({
    required this.icon,
    required this.label,
    required this.value,
    required this.tone,
  });

  final IconData icon;
  final String label;
  final String value;
  final _CardTone tone;

  @override
  Widget build(BuildContext context) {
    final color = tone == _CardTone.green
        ? const Color(0xFFEAF4EF)
        : const Color(0xFFFFEDF0);
    final iconColor = tone == _CardTone.green
        ? const Color(0xFF3F7E6E)
        : const Color(0xFFB65F71);

    return Card(
      child: Padding(
        padding: const EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: <Widget>[
            Container(
              width: 40,
              height: 40,
              decoration: BoxDecoration(color: color, shape: BoxShape.circle),
              child: Icon(icon, color: iconColor),
            ),
            const SizedBox(height: 14),
            Text(label, style: Theme.of(context).textTheme.bodySmall),
            const SizedBox(height: 4),
            Text(value, style: Theme.of(context).textTheme.titleLarge),
          ],
        ),
      ),
    );
  }
}

class _MovementCard extends StatelessWidget {
  const _MovementCard();

  @override
  Widget build(BuildContext context) {
    return Card(
      child: Padding(
        padding: const EdgeInsets.all(18),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: <Widget>[
            Row(
              children: <Widget>[
                Expanded(
                  child: Text(
                    '시간대별 움직임',
                    style: Theme.of(context).textTheme.titleMedium,
                  ),
                ),
                Text('센서 대기', style: Theme.of(context).textTheme.bodySmall),
              ],
            ),
            const SizedBox(height: 18),
            const _SoftBarChart(),
            const SizedBox(height: 16),
            const _EmptyState(
              icon: Icons.data_usage_outlined,
              title: '아직 기록된 태동 데이터가 없습니다',
              description: '기기가 연결되면 시간대별 감지 흐름이 이 카드에 표시됩니다.',
            ),
          ],
        ),
      ),
    );
  }
}

class _SoftBarChart extends StatelessWidget {
  const _SoftBarChart();

  @override
  Widget build(BuildContext context) {
    final bars = <double>[0.24, 0.42, 0.34, 0.58, 0.48, 0.72, 0.38];

    return SizedBox(
      height: 88,
      child: Row(
        crossAxisAlignment: CrossAxisAlignment.end,
        children: bars.map((heightFactor) {
          return Expanded(
            child: Padding(
              padding: const EdgeInsets.symmetric(horizontal: 4),
              child: FractionallySizedBox(
                heightFactor: heightFactor,
                alignment: Alignment.bottomCenter,
                child: DecoratedBox(
                  decoration: BoxDecoration(
                    color: const Color(0xFFA7CABE),
                    borderRadius: BorderRadius.circular(8),
                  ),
                ),
              ),
            ),
          );
        }).toList(),
      ),
    );
  }
}

